#!/bin/bash

# التأكد من تشغيل الأمر بصلاحيات الروت
if [[ $EUID -ne 0 ]]; then
   echo "[-] لازم تشغل الأمر بـ sudo: sudo simplify"
   exit 1
fi

# تحديد مجلد core الحقيقي داخل مستودع tols الحالي
CORE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "[*] جاري تبسيط أوامر المستودع وتحويلها لأوامر نظام حقيقية..."

# فحص الأوامر داخل مجلد core اللي ينتهي بـ -pgdjlgs
for file in "$CORE_DIR"/*-pgdjlgs; do
    if [ -x "$file" ]; then
        full_name=$(basename "$file")
        short_name="${full_name%-pgdjlgs}"
        
        # عمل رابط رمزي (Symlink) مباشرة في /usr/bin/ باسم الاختصار الصغير
        ln -sf "$file" "/usr/bin/$short_name"
        
        echo "  [+] تم تفعيل الأمر الحقيقي بالنظام: $short_name"
    fi
done

echo "[+] انتهى! الأوامر المختصرة شقالة الحين في كامل النظام بدون source!"
