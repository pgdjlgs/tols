#!/bin/bash

# تحديد مسار مجلد السكربتات الحالي في مستودعك تلقائياً
REPO_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "[*] جاري فحص المستودع وتبسيط الأوامر..."

# البحث عن أي ملف ينتهي بـ -pgdjlgs داخل مجلد السكربت
for file in "$REPO_BIN"/*-pgdjlgs; do
    # التأكد من أن الملف موجود وقابل للتنفيذ
    if [ -x "$file" ]; then
        # استخراج الاسم الكامل للملف (مثال: dw-pgdjlgs)
        full_name=$(basename "$file")
        # قص اللاحقة "-pgdjlgs" للحصول على الاسم المختصر (مثال: dw)
        short_name="${full_name%-pgdjlgs}"
        
        # تنظيف ملفات الإعدادات من الاختصار القديم لمنع التكرار عند إعادة التشغيل
        sed -i "/alias $short_name=/d" ~/.bashrc ~/.zshrc 2>/dev/null
        
        # حقن الاختصار النظيف في ملفات إعدادات Bash و Zsh
        echo "alias $short_name='$file'" >> ~/.bashrc
        echo "alias $short_name='$file'" >> ~/.zshrc
        
        echo "  [+] $full_name  ==>  $short_name"
    fi
done

echo "[+] تمت العملية بنجاح! افتح ترمينال جديد أو اكتب 'source ~/.bashrc' لتفعيل التغييرات الحالية."
