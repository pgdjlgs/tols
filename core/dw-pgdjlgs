#!/bin/bash
# dw-pgdjlgs - Dynamic Package Manager
# لا يحتاج لتعديل مهما زاد عدد الأدوات أو الإصدارات

TOOL=$1
VERSION=$2
REPO="pgdjlgs/tols"
LOCAL_BIN="/usr/local/bin"

# 1. منع التحميل المتكرر (Anti-Duplicate)
if [ -f "$LOCAL_BIN/$TOOL" ] && [ -z "$VERSION" ]; then
    echo "⚠️  The tool '$TOOL' is already installed."
    echo "💡 To update it to the latest version, run: up-pgdjlgs $TOOL"
    exit 0
fi

# 2. المنطق الديناميكي للإصدارات
# إذا المستخدم لم يكتب إصدار، نذهب لـ main تلقائياً
if [ -z "$VERSION" ]; then
    TARGET_VERSION="main"
else
    TARGET_VERSION="$VERSION"
fi

# 3. الرابط "العبقري" (يتشكل تلقائياً)
# أي أداة ترفعها في bin/ وأي وسم (Tag) تضعه، هذا الرابط سيجده
URL="https://raw.githubusercontent.com/$REPO/$TARGET_VERSION/bin/$TOOL"

echo "📡 Checking cloud for $TOOL (Version: $TARGET_VERSION)..."

# 4. محاولة التحميل
sudo curl -s -L -f -o "$LOCAL_BIN/$TOOL" "$URL"

if [ $? -eq 0 ]; then
    sudo chmod +x "$LOCAL_BIN/$TOOL"
    echo "✅ Successfully installed $TOOL from $TARGET_VERSION."
else
    echo "❌ Error: Tool or Version not found on GitHub."
    echo "Check: https://github.com/$REPO/tags"
    exit 1
fi
