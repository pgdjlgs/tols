#!/bin/bash

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Config
THEMES_DIR="/boot/grub/themes"
GRUB_DEFAULT="/etc/default/grub"
BACKUP_FILE="/etc/default/grub.bak.$(date +%F_%H%M%S)"
TMP_DIR="/tmp/grub_theme_tmp"
LOG="/var/log/grubtheme.log"

log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $1" | sudo tee -a "$LOG" >/dev/null
}

if [[ $EUID -ne 0 ]]; then
   echo -e "${RED}[!] لازم تشغل السكربت بصلاحيات root (sudo)${NC}"
   exit 1
fi

echo -e "${BLUE}==> Grub Theme Installer v1.0${NC}"
log "بدء تشغيل السكربت"

# فحص الأدوات الأساسية
for cmd in unzip tar grep find awk sed; do
    if ! command -v $cmd &> /dev/null; then
        echo -e "${RED}[-][xbps] الأداة '$cmd' مفقودة. ثبتها عبر: xbps-install -y $cmd${NC}"
        log "خطأ: الأداة $cmd غير موجودة في النظام."
        exit 1
    fi
done

extract_file() {
    local file="$1"
    local dest="$2"
    echo -e "${YELLOW}[*] جاري فك ضغط: $(basename "$file")${NC}"
    mkdir -p "$dest"
    
    case "$file" in
        *.zip) unzip -qo "$file" -d "$dest" ;;
        *.tar.gz|*.tgz) tar -xzf "$file" -C "$dest" ;;
        *.tar.xz|*.txz) tar -xJf "$file" -C "$dest" ;;
        *.tar) tar -xf "$file" -C "$dest" ;;
        *) echo -e "${RED}[!] صيغة الملف غير مدعومة.${NC}"; return 1 ;;
    esac
}

get_user_choice() {
    echo -e "\n${BLUE}الثيمات المتوفرة في $THEMES_DIR :${NC}"
    local i=1
    declare -A themes
    
    for d in "$THEMES_DIR"/*/; do
        if [[ -f "${d}theme.txt" ]]; then
            local name=$(basename "$d")
            echo -e "  [$i] - $name"
            themes[$i]="$d"
            ((i++))
        fi
    done
    
    if [[ $i -eq 1 ]]; then
        echo -e "  ${YELLOW}لا توجد ثيمات مثبتة حالياً.${NC}"
    fi
    echo -e "  [0] - تثبيت ثيم جديد من ملف مضغوط (.zip, .tar)"
    echo -e "  [q] - خروج"
    
    read -p "اختر رقم أو اسحب الملف هنا: " CHOICE
    
    if [[ "$CHOICE" == "q" ]]; then
        echo "تنبيه: تم إلغاء العملية."
        exit 0
    elif [[ "$CHOICE" == "0" ]]; then
        read -p "اسحب ملف الثيم المضغوط هنا: " FILE_PATH
        INPUT=$(echo "$FILE_PATH" | sed "s/'//g")
    elif [[ -n "${themes[$CHOICE]}" ]]; then
        INPUT="${themes[$CHOICE]}"
    else
        INPUT=$(echo "$CHOICE" | sed "s/'//g")
    fi
}

get_user_choice

# تجهيز مسار الفحص
if [[ -f "$INPUT" ]]; then
    extract_file "$INPUT" "$TMP_DIR"
    SEARCH_PATH="$TMP_DIR"
elif [[ -d "$INPUT" ]]; then
    SEARCH_PATH="$INPUT"
else
    echo -e "${RED}[!] المسار غير صحيح أو الملف غير موجود.${NC}"
    exit 1
fi

# البحث عن ملف theme.txt حسب الأولوية والدقة
echo -e "${YELLOW}[*] جاري البحث عن ملف theme.txt...${NC}"
THEME_FILE=""
for res in "1080p" "2k" "4k"; do
    THEME_FILE=$(find "$SEARCH_PATH" -name "theme.txt" | grep -i "$res" | head -n 1)
    [[ -n "$THEME_FILE" ]] && break
done

if [[ -z "$THEME_FILE" ]]; then
    THEME_FILE=$(find "$SEARCH_PATH" -name "theme.txt" | head -n 1)
fi

if [[ -z "$THEME_FILE" ]]; then
    echo -e "${RED}[!] لم يتم العثور على ملف theme.txt داخل المجلد.${NC}"
    rm -rf "$TMP_DIR" 2>/dev/null
    exit 1
fi

THEME_DIR=$(dirname "$THEME_FILE")
THEME_NAME=$(basename "$THEME_DIR")

echo -e "${GREEN}[+] تم العثور على الثيم: $THEME_NAME${NC}"

# نقل الملفات إذا لم تكن في مجلد الجروب الأساسي
if [[ "$THEME_DIR" != "$THEMES_DIR"* ]]; then
    echo -e "${YELLOW}[*] جاري نسخ الثيم إلى $THEMES_DIR ...${NC}"
    mkdir -p "$THEMES_DIR"
    cp -rf "$THEME_DIR" "$THEMES_DIR/"
    FINAL_PATH="$THEMES_DIR/$THEME_NAME/theme.txt"
    log "تم نسخ ثيم $THEME_NAME إلى مجلد الجروب"
else
    FINAL_PATH="$THEME_FILE"
fi

# النسخ الاحتياطي وتعديل ملف الإعدادات
echo -e "${YELLOW}[*] جاري عمل نسخة احتياطية للإعدادات في $BACKUP_FILE ...${NC}"
cp "$GRUB_DEFAULT" "$BACKUP_FILE"

echo -e "${YELLOW}[*] جاري تطبيق الثيم وتعديل ملف grub...${NC}"
sed -i "s|^#*GRUB_THEME=.*|GRUB_THEME=\"$FINAL_PATH\"|" "$GRUB_DEFAULT"
sed -i "s|^#*GRUB_TERMINAL_OUTPUT=.*|GRUB_TERMINAL_OUTPUT=\"gfxterm\"|" "$GRUB_DEFAULT"

# تحديث الجروب
echo -e "${BLUE}[*] جاري تشغيل grub-mkconfig لتحديث قائمة الإقلاع...${NC}"
grub-mkconfig -o /boot/grub/grub.cfg > /dev/null 2>&1

if [ $? -eq 0 ]; then
    echo -e "${GREEN}[+] تم تطبيق الثيم وتحديث الـ GRUB بنجاح ساكت!${NC}"
    log "تم تطبيق الثيم $THEME_NAME بنجاح."
else
    echo -e "${RED}[!] حدث خطأ أثناء تشغيل grub-mkconfig. يرجى مراجعة الملفات.${NC}"
    log "فشل تحديث grub-mkconfig"
fi

# تنظيف الملفات المؤقتة
rm -rf "$TMP_DIR" 2>/dev/null
exit 0
